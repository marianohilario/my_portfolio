# EmailJS configuration
# Copy this file to .env.local and fill in your EmailJS credentials
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id          # contact form template
NEXT_PUBLIC_EMAILJS_VISIT_TEMPLATE_ID=your_visit_template_id  # visit tracker template
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key                          # EmailJS private key (server-side only)
